<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CeluShop - Expertos en Móviles</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container"><a class="navbar-brand" href="#">CeluShop</a></div>
    </nav>

    <!-- Carrusel -->
    <div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1556656793-062ff987b50d?q=80&w=1200" class="d-block w-100" alt="Banner 1" style="height: 400px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=1200" class="d-block w-100" alt="Banner 2" style="height: 400px; object-fit: cover;">
            </div>
        </div>
    </div>

    <div class="container">
        <!-- Formulario de Adición -->
        <section class="card p-4 mb-5">
            <h3>Agregar Nuevo Celular</h3>
            <form action="/add" method="POST" enctype="multipart/form-data" class="row g-3">
                <div class="col-md-3"><input type="text" name="nombre" class="form-control" placeholder="Nombre" required></div>
                <div class="col-md-2"><input type="number" name="v_compra" class="form-control" placeholder="V. Compra"></div>
                <div class="col-md-2"><input type="number" name="v_venta" class="form-control" placeholder="V. Venta"></div>
                <div class="col-md-3"><input type="file" name="imagen" class="form-control" required></div>
                <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Guardar</button></div>
            </form>
        </section>

        <!-- Galería de Productos (4 por fila) -->
        <div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
            <% productos.forEach(p => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="/img/<%= p.ruta_imagen %>" class="card-img-top" alt="<%= p.nombre %>" style="height: 250px; object-fit: contain;">
                        <div class="card-body text-center">
                            <h5 class="card-title"><%= p.nombre %></h5>
                            <p class="text-success fw-bold">$<%= p.valor_venta %></p>
                            <a href="/delete/<%= p.idImg %>" class="btn btn-outline-danger btn-sm">Eliminar</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-4 pb-2 mt-5">
        <div class="container text-center">
            <div class="row">
                <div class="col-md-6">
                    <h5>Nuestras Redes</h5>
                    <p>🔵 Facebook | 📸 Instagram | 🐦 Twitter</p>
                </div>
                <div class="col-md-6">
                    <h5>Ubicación</h5>
                    <p>📍 Google Maps: <a href="https://maps.google.com" target="_blank" class="text-info">Ver Tienda</a></p>
                </div>
            </div>
            <hr>
            <p>&copy; 2026 CeluShop - Calidad garantizada</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
